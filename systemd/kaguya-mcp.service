[Unit]
Description=Kaguya MemPalace MCP Server
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/apps/kaguya-mempalace
Environment=PYTHONUNBUFFERED=1
Environment=HOME=/home/ubuntu
Environment=PATH=/home/ubuntu/apps/kaguya-mempalace/.venv/bin:/home/ubuntu/.local/bin:/usr/local/bin:/usr/bin:/bin
EnvironmentFile=/home/ubuntu/apps/kaguya-mempalace/.env
ExecStart=/home/ubuntu/apps/kaguya-mempalace/.venv/bin/python -m app.mcp.server
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
