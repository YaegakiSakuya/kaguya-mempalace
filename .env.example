OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
SYSTEM_NAME=Kaguya Telegram Gateway
BASE_DIR=/home/ubuntu/apps/kaguya-gateway
PALACE_PATH=/home/ubuntu/apps/kaguya-gateway/runtime/palace
CHATS_DIR=/home/ubuntu/apps/kaguya-gateway/runtime/chats
LOGS_DIR=/home/ubuntu/apps/kaguya-gateway/runtime/logs
STATE_DIR=/home/ubuntu/apps/kaguya-gateway/runtime/state
WAKEUP_FILE=/home/ubuntu/apps/kaguya-gateway/runtime/wakeup.txt
AUTOSAVE_USER_MESSAGE_INTERVAL=15
SEARCH_TOP_K=8
RECENT_TURNS=8
