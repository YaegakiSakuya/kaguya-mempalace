# ========== LLM (主对话模型) ==========
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=

# ========== Telegram Bot ==========
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# ========== 系统配置 ==========
SYSTEM_NAME="Kaguya Telegram Gateway"
BASE_DIR=/home/ubuntu/apps/kaguya-mempalace
PALACE_PATH=/home/ubuntu/apps/kaguya-mempalace/runtime/palace
CHATS_DIR=/home/ubuntu/apps/kaguya-mempalace/runtime/chats
LOGS_DIR=/home/ubuntu/apps/kaguya-mempalace/runtime/logs
STATE_DIR=/home/ubuntu/apps/kaguya-mempalace/runtime/state
WAKEUP_FILE=/home/ubuntu/apps/kaguya-mempalace/runtime/wakeup.txt
AUTOSAVE_USER_MESSAGE_INTERVAL=30
SEARCH_TOP_K=8
RECENT_TURNS=30
INSPECTOR_PORT=8765
INSPECTOR_TOKEN=

# ========== Media Pipeline (视觉 + 语音的共享元数据 Supabase project) ==========
# kaguya-media 项目:images 表 + voices 表 + message_images 表
KAGUYA_MEDIA_URL=
KAGUYA_MEDIA_SERVICE_KEY=
# 本地上传目录(图片 + 语音落盘):默认 $BASE_DIR/runtime/uploads
MEDIA_UPLOADS_DIR=

# ========== 硅基流动 (VL 视觉理解 + 未来 ASR) ==========
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# VL 模型:Qwen3-VL-30B-A3B-Instruct 是实测响应 ~5s 的甜点,235B 顶配会超时
VL_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct

# ========== Tavily (LLM 联网搜索工具 web_search) ==========
TAVILY_API_KEY=

# ========== MiniMax (TTS 语音合成 + voice cloning) ==========
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# 克隆得到的 voice_id。没配置则对应语种的语音功能不可用。
# 克隆流程:上传参考音 → 调 /v1/voice_clone → 首次正式合成扣 9.9 元解锁费 → 永久保留
MINIMAX_VOICE_ID_JA=
MINIMAX_VOICE_ID_ZH=
